    ('FILE_AM_RR'),
    ('FILE_NOCDR'),
    ('FILE_AM_DI'),
    ('FILE_NOALA'),
    ('FILE_NOALB'),
    ('FILE_NOALU'),
    ('FILE_NOALC'),
    ('FILE_AM_BC'),
    ('FILE_AM_LI'),
    ('FILE_AM_RM'),
    ('FILE_AM_SS'),
    ('ADCORP_NULL'),
    -- Skipped events/filing types
    ('FILE_COGS1'),
    ('FILE_CHGJU'),
    ('FILE_NWPTA'),
